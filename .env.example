# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (PostgreSQL — e.g. Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# Optional: direct connection for migrations / tooling (Neon)
# DATABASE_URL_UNPOOLED=

# Clerk (auth + orgs + webhooks)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhook signing secret from Clerk Dashboard → Webhooks → your endpoint
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Stripe (billing)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_PER_FILE=

# Anthropic Claude API (document extraction, Q&A)
ANTHROPIC_API_KEY=
UPLOAD_DIR=
FILINGS_DIR=                    # Optional: custom filings directory (defaults to ./filings)

# SendGrid (transactional email)
SENDGRID_API_KEY=                       # SendGrid API key for email notifications
EMAIL_FROM=notifications@titlecomply.com # From email address (falls back to SENDGRID_FROM_EMAIL if unset)
EMAIL_FROM_NAME=TitleComply              # From display name
# SENDGRID_FROM_EMAIL=                  # Legacy alias for EMAIL_FROM
NEXT_PUBLIC_SITE_URL=                   # Optional: public site URL for email links (falls back to NEXT_PUBLIC_APP_URL)

# Redis (BullMQ background jobs)
REDIS_URL=

# Object storage (Cloudflare R2 or AWS S3)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=

# Application encryption (AES-256-GCM — derive from org + master; see SPEC §9)
ENCRYPTION_MASTER_KEY=

# Sentry (monitoring)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# CI / build (optional dummy URL so Prisma tooling runs without a real DB)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/titlecomply"
