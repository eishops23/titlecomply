# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (PostgreSQL — e.g. Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# Optional: direct connection for migrations / tooling (Neon)
# DATABASE_URL_UNPOOLED=

# Clerk (auth — not configured yet)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Stripe (billing — not configured yet)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Anthropic Claude API (document extraction, Q&A)
ANTHROPIC_API_KEY=

# SendGrid (transactional email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Redis (BullMQ background jobs)
REDIS_URL=

# Object storage (Cloudflare R2 or AWS S3)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=

# Application encryption (AES-256-GCM — derive from org + master; see SPEC §9)
ENCRYPTION_MASTER_KEY=

# Sentry (monitoring)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# CI / build (optional dummy URL so Prisma tooling runs without a real DB)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/titlecomply"
